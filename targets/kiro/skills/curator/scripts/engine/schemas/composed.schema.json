{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "composed.json",
  "type": "object",
  "required": ["source", "summary", "proposals", "related_sources"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "object",
      "required": ["path", "basename", "type"],
      "properties": {
        "path":     { "type": "string" },
        "basename": { "type": "string" },
        "type":     { "enum": ["pdf", "epub", "article", "video", "unknown"] }
      }
    },
    "summary": { "type": "string", "minLength": 1 },
    "proposals": {
      "type": "object",
      "required": ["keywords", "people", "models", "synthesis"],
      "properties": {
        "keywords":  { "type": "array" },
        "people":    { "type": "array" },
        "models":    { "type": "array" },
        "synthesis": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "action", "rationale", "proposed_frontmatter", "proposed_body"],
            "properties": {
              "id":     { "type": "string", "pattern": "^syn-[0-9]+$" },
              "path":   { "type": "string" },
              "action": { "enum": ["create", "extend"] },
              "rationale": { "type": "string" },
              "proposed_frontmatter": { "type": "object" },
              "proposed_body": { "type": "string" }
            }
          }
        }
      }
    },
    "related_sources": { "type": "array" }
  }
}
