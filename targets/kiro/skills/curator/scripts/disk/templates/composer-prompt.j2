# Initialize the skeleton once:
{{ disk }} composed-init --workdir {{ workdir }} \
    --source-path "<path from summary.json's source or fetch result>" \
    --source-type pdf | epub | article | video | unknown \
    --source-basename "<basename>"

# Set the summary (body of the composed.summary field):
{{ disk }} composed-set-summary --workdir {{ workdir }} \
    --summary-file {{ workdir }}/bodies/composed-summary.txt

# Append reconciled keywords / people / models (repeat per item):
{{ disk }} composed-add --workdir {{ workdir }} \
    --kind keyword --id kw-1 --name "..." \
    --action create|extend --rationale "..." \
    [--match-existing "..."] \
    --body-file {{ workdir }}/bodies/kw-1.body.md \
    --frontmatter-file {{ workdir }}/bodies/kw-1.fm.yml

{{ disk }} composed-add --workdir {{ workdir }} --kind person ...
{{ disk }} composed-add --workdir {{ workdir }} --kind model  ...

# Append planned synthesis pages (covers ≥ 3 atomics each):
{{ disk }} composed-add --workdir {{ workdir }} \
    --kind synthesis --id syn-1 --path "21 SYNTHESIS/<topic>.md" \
    --action create --rationale "..." \
    --body-file {{ workdir }}/bodies/syn-1.body.md \
    --frontmatter-file {{ workdir }}/bodies/syn-1.fm.yml

# Append filtered related_sources (≤ 10 entries; drop items already
# present under 10 SOURCES/ in the vault context):
{{ disk }} composed-add-related-source --workdir {{ workdir }} \
    --type paper|book|url|video --title "..." --reason "..." \
    [--authors "Last, First" ...] [--year ...] \
    [--arxiv ...] [--doi ...] [--isbn ...] [--url ...]

