{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "report-vars.json",
  "description": "Flattened form of composed.json consumed by render.sh in strict mode. Each item optionally carries _judge_issues injected from the paired verdict file.",
  "type": "object",
  "required": ["summary", "keywords", "people", "models", "synthesis", "related_sources"],
  "additionalProperties": false,
  "properties": {
    "summary":         { "type": "string" },
    "keywords":        { "type": "array" },
    "people":          { "type": "array" },
    "models":          { "type": "array" },
    "synthesis":       { "type": "array" },
    "related_sources": { "type": "array" }
  }
}
