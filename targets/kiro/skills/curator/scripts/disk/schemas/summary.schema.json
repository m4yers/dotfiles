{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "summary.json",
  "type": "object",
  "required": ["summary", "key_claims"],
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "key_claims": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "maxItems": 20
    }
  }
}
