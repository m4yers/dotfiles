{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sources.json",
  "type": "object",
  "required": ["referenced"],
  "additionalProperties": false,
  "properties": {
    "referenced": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "mention_context"],
        "properties": {
          "id":    { "type": "string", "pattern": "^src-[0-9]+$" },
          "type":  { "enum": ["paper", "book", "url", "video"] },
          "title": { "type": "string" },
          "authors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "year":   { "type": ["integer", "null"] },
          "arxiv":  { "type": ["string", "null"] },
          "doi":    { "type": ["string", "null"] },
          "isbn":   { "type": ["string", "null"] },
          "url":    { "type": ["string", "null"] },
          "mention_context": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
