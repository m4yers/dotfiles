{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "context (vault.sh context stdout)",
  "description": "Per-type existing-name lists used by extractors for dedup, plus the vault scope rules. Produced by vault.sh context on stdout; not persisted by default.",
  "type": "object",
  "required": ["scope_rules", "vault_root"],
  "additionalProperties": false,
  "properties": {
    "keywords":  { "$ref": "#/$defs/entries" },
    "people":    { "$ref": "#/$defs/entries" },
    "models":    { "$ref": "#/$defs/entries" },
    "synthesis": { "$ref": "#/$defs/entries" },
    "scope_rules": {
      "type": "object",
      "required": ["writable_prefixes", "read_only_dirs", "binary_suffixes"],
      "additionalProperties": false,
      "properties": {
        "writable_prefixes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "read_only_dirs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "binary_suffixes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "vault_root": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "size", "aliases"],
        "additionalProperties": false,
        "properties": {
          "name":    { "type": "string", "minLength": 1 },
          "path":    { "type": "string", "minLength": 1 },
          "size":    { "type": "integer", "minimum": 0 },
          "aliases": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
