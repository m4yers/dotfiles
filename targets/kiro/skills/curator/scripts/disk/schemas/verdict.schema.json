{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "verdicts.json",
  "description": "Per-extractor judge verdicts. Written to <workdir>/verdicts/<agent>.json after the orchestrator aggregates per-attempt files.",
  "type": "object",
  "required": ["kind", "attempts", "verdicts", "meta"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "enum": [
        "summary",
        "sources",
        "keywords",
        "people",
        "models"
      ]
    },
    "attempts": { "type": "integer", "minimum": 1, "maximum": 3 },
    "verdicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/verdict" }
    },
    "meta": {
      "type": "object",
      "required": ["items_total", "accept", "review", "reject"],
      "additionalProperties": false,
      "properties": {
        "items_total": { "type": "integer", "minimum": 0 },
        "accept":      { "type": "integer", "minimum": 0 },
        "review":      { "type": "integer", "minimum": 0 },
        "reject":      { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["severity", "category", "message"],
      "additionalProperties": false,
      "properties": {
        "severity": { "enum": ["error", "warning"] },
        "category": {
          "enum": [
            "unsupported_claim",
            "citation_missing",
            "citation_mismatch",
            "tone",
            "anatomy",
            "naming",
            "match_existing"
          ]
        },
        "location":        { "type": "string" },
        "message":         { "type": "string", "minLength": 1 },
        "source_evidence": { "type": "string" }
      }
    },
    "verdict": {
      "type": "object",
      "required": ["id", "verdict"],
      "additionalProperties": false,
      "properties": {
        "id":                 { "type": "string", "minLength": 1 },
        "verdict":            { "enum": ["ACCEPT", "REVIEW", "REJECT"] },
        "issues":             { "type": "array", "items": { "$ref": "#/$defs/issue" } },
        "rewrite_suggestion": { "type": ["string", "null"] },
        "retry_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/retry" }
        }
      }
    },
    "retry": {
      "type": "object",
      "required": ["attempt", "verdict"],
      "additionalProperties": false,
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "verdict": { "enum": ["ACCEPT", "REVIEW", "REJECT", "SCHEMA_FAILURE"] },
        "issues":  { "type": "array", "items": { "$ref": "#/$defs/issue" } }
      }
    }
  }
}
