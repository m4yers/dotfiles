{# templates/vault/quote.j2 — vault page for type=quote.

   Used for the ``quotes`` extractor kind. Build-replica
   currently iterates by ``item.name``; quotes identify by
   ``text``. This template is wired but iteration plumbing
   needs ``text`` support before it activates.
-#}
{%- set section_body -%}
> {{ item.text.strip() }}

{% if item.get('speaker') %}**— {{ item.get('speaker') }}**{% endif %}{% if item.get('context') %} · {{ item.get('context') }}{% endif %}

— captured in [[{{ source_path }}]]
{%- endset -%}
{%- if mode == 'section' -%}
{{ section_body }}
{%- else -%}
---
type: quote
{%- if item.get('speaker') %}
speaker: "{{ item.get('speaker') }}"
{%- endif %}
sources:
  - "{{ source_path }}"
last_updated: {{ today }}
---

{# Quotes have no title; the body opens with the first source's
   ``## Source:`` section, which contains the quote itself. #}
## Source: {{ source_basename }}

{{ section_body }}
{%- endif -%}
