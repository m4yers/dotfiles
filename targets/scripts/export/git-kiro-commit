#!/bin/bash
# git-kiro-commit — Stage all changes, generate a commit message with Kiro,
# and push after confirmation.
#
# Usage: git-kiro-commit
#
# Flow:
#   1. Stages all tracked and untracked files (git add -A)
#   2. Bails out if there's nothing to commit
#   3. Sends the cached diff to kiro-cli to generate a commit message
#   4. Prints the message and asks for confirmation
#   5. Commits and pushes on approval
#
# Requirements: git, kiro-cli
# Vim binding: nnoremap <leader>gk :!git-kiro-commit<cr>

set -euo pipefail

if ! command -v kiro-cli &>/dev/null; then
  echo "Error: kiro-cli not found in PATH."
  exit 1
fi

git add -A
if git diff --cached --quiet; then
  echo "Nothing to commit."
  exit 1
fi

diff_file=$(mktemp)
trap 'rm -f "$diff_file"' EXIT
git diff --cached > "$diff_file"

prompt="Write a concise git commit message for the following diff. Output ONLY the commit message — a subject line (max 72 chars), then optionally a blank line and a short body. No markdown, no fences, no explanation.

$(cat "$diff_file")"

msg=$(kiro-cli chat --no-interactive --trust-tools= "$prompt")

echo ""
echo "--- Proposed commit message ---"
echo "$msg"
echo "-------------------------------"
read -p "Commit with this message? [Y/n] " confirm
if [[ "${confirm:-Y}" =~ ^[Yy]$ ]]; then
  git commit -m "$msg"
  git push
fi
